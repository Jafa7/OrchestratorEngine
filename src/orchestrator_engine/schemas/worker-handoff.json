{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestrator-engine://schemas/worker-handoff",
  "title": "Optional worker handoff evidence",
  "schema_version": 1,
  "kind": "WORKER_HANDOFF",
  "type": "object",
  "required": ["schema_version", "kind", "summary"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "WORKER_HANDOFF"},
    "summary": {"type": "string", "maxLength": 4096},
    "evidence": {"type": "array", "maxItems": 64},
    "risks": {"type": "array", "maxItems": 32},
    "next_actions": {"type": "array", "maxItems": 32}
  },
  "additionalProperties": true
}
