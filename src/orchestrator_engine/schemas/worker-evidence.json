{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestrator-engine://schemas/worker-evidence",
  "title": "Worker evidence",
  "schema_version": 1,
  "kind": "WORKER_EVIDENCE",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "task_id",
    "worker",
    "command",
    "prompt_file",
    "prompt_sha256",
    "worker_config",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "WORKER_EVIDENCE"},
    "task_id": {"type": "string", "minLength": 1},
    "worker": {"type": "string", "minLength": 1},
    "command": {"type": "array", "items": {"type": "string"}},
    "prompt_file": {"type": "string"},
    "prompt_sha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "effective_prompt_file": {"type": "string", "minLength": 1},
    "effective_prompt_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "worker_policy": {
      "$ref": "orchestrator-engine://schemas/worker-policy-snapshot"
    },
    "worker_config": {"type": "object"},
    "availability_preflight": {
      "type": "object",
      "required": ["mode", "status", "checked_at"],
      "properties": {
        "mode": {"enum": ["block-unavailable", "require-available"]},
        "status": {"enum": ["available", "unavailable", "probe_error", "not_configured"]},
        "checked_at": {"type": "string", "format": "date-time"},
        "exit_code": {"type": "integer"},
        "output_bytes": {"type": "integer", "minimum": 0},
        "output_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "error": {"type": "string"}
      },
      "additionalProperties": false
    },
    "intent_admission": {
      "type": "object",
      "required": ["mode", "evaluated_at", "permission_profile"],
      "properties": {
        "mode": {"enum": ["permissions", "strict"]},
        "evaluated_at": {"type": "string", "format": "date-time"},
        "permission_profile": {
          "type": ["string", "null"],
          "enum": ["readonly", "restricted", "full", null]
        },
        "worker_admission": {"type": "object"}
      },
      "additionalProperties": false
    },
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "wake_target": {"$ref": "orchestrator-engine://schemas/wake-target"}
  },
  "additionalProperties": true
}
