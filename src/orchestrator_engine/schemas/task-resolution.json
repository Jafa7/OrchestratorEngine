{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"orchestrator-engine://schemas/task-resolution","title":"Task resolution","schema_version":1,"kind":"WORKER_TASK_RESOLUTION","type":"object","required":["schema_version","kind","task_id","status","reason","previous_task_status","created_at"],"properties":{"schema_version":{"const":1},"kind":{"const":"WORKER_TASK_RESOLUTION"},"task_id":{"type":"string","minLength":1},"status":{"enum":["acknowledged","superseded"]},"reason":{"type":"string","minLength":1},"previous_task_status":{"enum":["completed","failed","timed_out","rate_limited","invalid_result","cancelled"]},"diagnostic_codes":{"type":"array","minItems":1,"maxItems":64,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z][a-z0-9_]{0,127}$"}},"superseded_by_task_id":{"type":"string","minLength":1},"previous_resolution":{"type":"object"},"created_at":{"type":"string","format":"date-time"}},"allOf":[{"if":{"properties":{"status":{"const":"superseded"}}},"then":{"required":["superseded_by_task_id"]}},{"if":{"properties":{"previous_task_status":{"const":"completed"}}},"then":{"properties":{"status":{"const":"acknowledged"}},"required":["diagnostic_codes"]}}],"additionalProperties":true}
