{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"orchestrator-engine://schemas/task-resolution","title":"Task resolution","schema_version":1,"kind":"WORKER_TASK_RESOLUTION","type":"object","required":["schema_version","kind","task_id","status","reason","previous_task_status","created_at"],"properties":{"schema_version":{"const":1},"kind":{"const":"WORKER_TASK_RESOLUTION"},"task_id":{"type":"string","minLength":1},"status":{"enum":["acknowledged","superseded"]},"reason":{"type":"string","minLength":1},"previous_task_status":{"enum":["failed","timed_out","rate_limited","invalid_result","cancelled"]},"superseded_by_task_id":{"type":"string","minLength":1},"previous_resolution":{"type":"object"},"created_at":{"type":"string","format":"date-time"}},"allOf":[{"if":{"properties":{"status":{"const":"superseded"}}},"then":{"required":["superseded_by_task_id"]}}],"additionalProperties":true}
