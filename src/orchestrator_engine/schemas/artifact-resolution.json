{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"orchestrator-engine://schemas/artifact-resolution","title":"Hash-bound artifact resolution","schema_version":1,"kind":"ORCHESTRATOR_ARTIFACT_RESOLUTION","type":"object","required":["schema_version","kind","artifact_path","artifact_sha256","diagnostic_code","reason","created_at"],"properties":{"schema_version":{"const":1},"kind":{"const":"ORCHESTRATOR_ARTIFACT_RESOLUTION"},"artifact_path":{"type":"string","minLength":1,"maxLength":4096,"pattern":"^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},"artifact_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"diagnostic_code":{"const":"schema_metadata_malformed"},"observed_kind":{"type":["string","null"],"maxLength":128},"observed_schema_version":{"type":["string","number","boolean","null"],"maxLength":128},"reason":{"type":"string","minLength":1,"maxLength":4096},"created_at":{"type":"string","format":"date-time"}},"additionalProperties":true}
