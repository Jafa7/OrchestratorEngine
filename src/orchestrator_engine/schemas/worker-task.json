{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestrator-engine://schemas/worker-task",
  "title": "Worker task descriptor",
  "schema_version": 1,
  "kind": "WORKER_TASK",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "task_id",
    "worker",
    "status",
    "prompt_file",
    "task_dir",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "WORKER_TASK"},
    "task_id": {"type": "string", "minLength": 1},
    "worker": {"type": "string", "minLength": 1},
    "status": {
      "enum": [
        "queued",
        "starting",
        "running",
        "cancelling",
        "completed",
        "failed",
        "timed_out",
        "rate_limited",
        "invalid_result",
        "cancelled"
      ]
    },
    "prompt_file": {"type": "string", "minLength": 1},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "task_prompt_file": {"type": "string", "minLength": 1},
    "task_prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "effective_prompt_file": {"type": "string", "minLength": 1},
    "effective_prompt_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "worker_policy": {
      "anyOf": [
        {"$ref": "orchestrator-engine://schemas/worker-policy-snapshot"},
        {"type": "null"}
      ]
    },
    "task_dir": {"type": "string", "minLength": 1},
    "intent_file": {"type": "string", "minLength": 1},
    "intent_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "task_intent": {"type": "object"},
    "dispatch_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "dispatch_claim_path": {"type": "string", "minLength": 1},
    "retry_lineage": {"type": "object"},
    "runtime_policy": {"type": "object"},
    "progress": {"type": "object"},
    "usage": {"$ref": "orchestrator-engine://schemas/worker-usage"},
    "worker_handoff": {"type": "object"},
    "declared_output_dir": {"type": "string", "minLength": 1},
    "declared_outputs": {"type": "object"},
    "output_collection_error": {"type": "string", "minLength": 1},
    "supervisor_log": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "event_path": {"type": "string"},
    "signal_path": {"type": "string"},
    "supervisor_pid": {"type": "integer"},
    "lease_path": {"type": "string", "minLength": 1},
    "worker_pid": {"type": "integer"},
    "worker_pgid": {"type": "integer"},
    "last_alive_at": {"type": "string", "format": "date-time"},
    "wake_target": {"$ref": "orchestrator-engine://schemas/wake-target"},
    "warnings": {"type": "array"}
  },
  "additionalProperties": true
}
